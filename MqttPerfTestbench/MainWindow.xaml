<Window x:Class="MqttPerfTestbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MqttPerfTestbench.ViewModels"
        mc:Ignorable="d"
        Title="Multi-Protocol Pipeline Testbench" Height="750" Width="950"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="0,0,0,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="#808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="High-Performance Data Pipeline &amp; Protocol Testbench" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#007ACC"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Column 1: Pipeline & Transport Config -->
            <Border Grid.Column="0" Background="#252526" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="1. Pipeline Setup" FontSize="16" FontWeight="SemiBold" Foreground="#4CAF50" Margin="0,0,0,10"/>

                    <Label Content="Image Size (MB)"/>
                    <TextBox Text="{Binding PayloadSizeMb, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <Label Content="Width"/>
                            <TextBox Text="{Binding ImageWidth, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Label Content="Height"/>
                            <TextBox Text="{Binding ImageHeight, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="DQCM Predictor (2D requires Width)"/>
                    <ComboBox ItemsSource="{Binding Predictors}" SelectedItem="{Binding SelectedPredictor}" DisplayMemberPath="Name"/>

                    <Label Content="Compressor"/>
                    <ComboBox ItemsSource="{Binding Compressors}" SelectedItem="{Binding SelectedCompressor}" DisplayMemberPath="Name"/>

                    <Label Content="Compression Level (0-9)"/>
                    <TextBox Text="{Binding CompressionLevel, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="2. Transport Setup" FontSize="16" FontWeight="SemiBold" Foreground="#2196F3" Margin="0,15,0,10"/>
                    
                    <Label Content="Protocol"/>
                    <ComboBox ItemsSource="{Binding Protocols}" SelectedItem="{Binding SelectedProtocol}"/>

                    <Label Content="Target FPS (1-120)"/>
                    <TextBox Text="{Binding TargetFps, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <Label Content="Chunk Size (MB) (0 for No Chunking)"/>
                    <TextBox Text="{Binding ChunkSizeMb, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Column 2: Advanced Tuning & Controls -->
            <Border Grid.Column="2" Background="#252526" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="3. Advanced Tuning" FontSize="16" FontWeight="SemiBold" Foreground="#FF9800" Margin="0,0,0,15"/>
                    
                    <CheckBox Content="TCP NoDelay (Disable Nagle)" IsChecked="{Binding TcpNoDelay}" Foreground="White" Margin="0,0,0,10"/>
                    <CheckBox Content="Parallel Chunk Publishing" IsChecked="{Binding ParallelChunkPublish}" Foreground="White" Margin="0,0,0,15"/>

                    <Label Content="TCP/ZMQ Socket Buffer Size (MB)"/>
                    <TextBox Text="{Binding SocketBufferSizeMb, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="MQTT/ZMQ High Watermark / Queue limit"/>
                    <TextBox Text="{Binding MaxPendingMessages, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="MQTT QoS Level (0, 1, 2)"/>
                    <TextBox Text="{Binding Qos, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Start Test" Command="{Binding StartTestCommand}" IsEnabled="{Binding IsRunning, Converter={x:Static local:InverseBooleanConverter.Instance}}"/>
                        <Button Grid.Column="2" Content="Stop Test" Command="{Binding StopTestCommand}" IsEnabled="{Binding IsRunning}" Background="#D13438"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Column 3: Real-Time Metrics -->
            <Border Grid.Column="4" Background="#252526" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Real-Time Metrics" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <!-- Pipeline Stats -->
                    <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Margin="0,0,0,15" Padding="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Pipeline Performance (Once)" Foreground="#A0A0A0" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Prediction:" Width="90"/>
                                <TextBlock Text="{Binding PredictionTimeMs, StringFormat={}{0:F2} ms}" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Compression:" Width="90"/>
                                <TextBlock Text="{Binding CompressionTimeMs, StringFormat={}{0:F2} ms}" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Comp. Size:" Width="90"/>
                                <TextBlock Text="{Binding CompressedSizeMb, StringFormat={}{0:F2} MB}" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Network Stats -->
                    <TextBlock Text="Network Performance (Live)" Foreground="#A0A0A0" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Actual FPS" FontSize="14" Foreground="#A0A0A0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="{Binding CurrentFps, StringFormat={}{0:F1}}" FontSize="32" FontWeight="Bold" Foreground="#4CAF50"/>
                        <TextBlock Text=" fps" FontSize="16" Foreground="#A0A0A0" Margin="5,12,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Bandwidth" FontSize="14" Foreground="#A0A0A0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="{Binding CurrentBandwidthMb, StringFormat={}{0:F2}}" FontSize="32" FontWeight="Bold" Foreground="#2196F3"/>
                        <TextBlock Text=" MB/s" FontSize="16" Foreground="#A0A0A0" Margin="5,12,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Network Latency" FontSize="14" Foreground="#A0A0A0"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding AverageLatencyMs, StringFormat={}{0:F2}}" FontSize="32" FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock Text=" ms" FontSize="16" Foreground="#A0A0A0" Margin="5,12,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="2" Text="{Binding IsRunning, StringFormat='Status: {0}'}" 
                   Margin="0,15,0,0" FontSize="14" Foreground="#808080"
                   HorizontalAlignment="Right"/>
    </Grid>
</Window>
