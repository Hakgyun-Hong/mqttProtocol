<Window x:Class="MqttPerfTestbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MqttPerfTestbench.ViewModels"
        mc:Ignorable="d"
        Title="MQTT Performance Testbench" Height="600" Width="800"
        Background="#1E1E1E" Foreground="White"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    
    <Window.Resources>
        <!-- Styles for modern look -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0098FF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3E3E42"/>
                    <Setter Property="Foreground" Value="#808080"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="MQTT High-Performance Transmission Testbench" 
                   FontSize="24" FontWeight="Bold" Margin="0,0,0,20" Foreground="#007ACC"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Configuration Panel -->
            <Border Grid.Column="0" Background="#252526" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <Label Content="Target FPS (1-60)"/>
                    <TextBox Text="{Binding TargetFps, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <Label Content="Payload Size (MB)"/>
                    <TextBox Text="{Binding PayloadSizeMb, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <Label Content="Chunk Size (MB) (0 for No Chunking)"/>
                    <TextBox Text="{Binding ChunkSizeMb, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <Label Content="QoS Level (0, 1, 2)"/>
                    <TextBox Text="{Binding Qos, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                    <Border BorderBrush="#3F3F46" BorderThickness="0,1,0,0" Margin="0,0,0,15" Padding="0,15,0,0">
                        <StackPanel>
                            <TextBlock Text="Advanced Tuning" FontSize="14" FontWeight="SemiBold" Foreground="#007ACC" Margin="0,0,0,10"/>
                            
                            <CheckBox Content="TCP NoDelay (Disable Nagle)" IsChecked="{Binding TcpNoDelay}" Foreground="White" Margin="0,0,0,10"/>
                            <CheckBox Content="Parallel Chunk Publishing" IsChecked="{Binding ParallelChunkPublish}" Foreground="White" Margin="0,0,0,10"/>

                            <Label Content="Socket Buffer Size (MB)"/>
                            <TextBox Text="{Binding SocketBufferSizeMb, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                            <Label Content="Max Pending Messages (Broker Queue)"/>
                            <TextBox Text="{Binding MaxPendingMessages, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Start Test" Command="{Binding StartTestCommand}" IsEnabled="{Binding IsRunning, Converter={x:Static local:InverseBooleanConverter.Instance}}"/>
                        <Button Grid.Column="2" Content="Stop Test" Command="{Binding StopTestCommand}" IsEnabled="{Binding IsRunning}" Background="#D13438"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Metrics Panel -->
            <Border Grid.Column="2" Background="#252526" CornerRadius="8" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Real-Time Metrics" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Actual FPS:" FontSize="20" Foreground="#A0A0A0" Width="150"/>
                        <TextBlock Text="{Binding CurrentFps, StringFormat={}{0:F1}}" FontSize="36" FontWeight="Bold" Foreground="#4CAF50"/>
                        <TextBlock Text=" fps" FontSize="20" Foreground="#A0A0A0" Margin="10,12,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Bandwidth:" FontSize="20" Foreground="#A0A0A0" Width="150"/>
                        <TextBlock Text="{Binding CurrentBandwidthMb, StringFormat={}{0:F2}}" FontSize="36" FontWeight="Bold" Foreground="#2196F3"/>
                        <TextBlock Text=" MB/s" FontSize="20" Foreground="#A0A0A0" Margin="10,12,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Latency:" FontSize="20" Foreground="#A0A0A0" Width="150"/>
                        <TextBlock Text="{Binding AverageLatencyMs, StringFormat={}{0:F2}}" FontSize="36" FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock Text=" ms" FontSize="20" Foreground="#A0A0A0" Margin="10,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <TextBlock Grid.Row="2" Text="{Binding IsRunning, StringFormat='Status: {0}'}" 
                   Margin="0,15,0,0" FontSize="14" Foreground="#808080"
                   HorizontalAlignment="Right"/>
    </Grid>
</Window>
